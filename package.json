{
  "name": "google-bottakuri-checker",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "npm --prefix worker run dev",
    "build": "vite build",
    "build:api": "npm --prefix worker run build",
    "preview": "vite preview",
    "test:root": "vitest run --config vitest.config.ts",
    "test:worker": "npm --prefix worker run test",
    "test": "npm run test:root && npm run test:worker",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:worker": "npm --prefix worker run typecheck"
  },
  "dependencies": {
    "lucide-react": "^0.554.0",
    "motion": "^12.38.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "recharts": "^3.4.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^28.0.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.0.18"
  }
}
