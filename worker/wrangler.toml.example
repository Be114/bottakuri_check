name = "bottakuri-check-api"
main = "src/index.ts"
compatibility_date = "2026-02-06"
workers_dev = true

[vars]
ALLOWED_ORIGINS = "http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173,https://bottakuri-check.pages.dev,https://bottakurichecker.uk"
DAILY_BUDGET_USD = "5"
WORST_CASE_COST_USD = "0.25"
CACHE_TTL_SECONDS = "86400"
PER_MINUTE_LIMIT = "5"
PER_DAY_NEW_ANALYSIS_LIMIT = "20"
OPENROUTER_MAX_TOKENS = "3200"
OPENROUTER_WEB_MAX_RESULTS = "5"
REVIEW_SAMPLE_LIMIT = "12"
NEARBY_ANALYSIS_REVIEW_SAMPLE_LIMIT = "16"
DAY_ROLLOVER_TIMEZONE = "Asia/Tokyo"
OPENROUTER_SITE_URL = "https://bottakurichecker.uk"
OPENROUTER_APP_NAME = "Bottakuri Checker"
# Empty string uses the built-in default chain-store keyword list.
CHAIN_STORE_KEYWORDS = ""

[[kv_namespaces]]
binding = "APP_KV"
id = "REPLACE_WITH_KV_NAMESPACE_ID"
preview_id = "REPLACE_WITH_PREVIEW_KV_NAMESPACE_ID"

[[durable_objects.bindings]]
name = "COUNTERS"
class_name = "AtomicCounter"

[[migrations]]
tag = "v1"
new_classes = ["AtomicCounter"]
